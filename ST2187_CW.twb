      <column caption='Discount Bracket' datatype='string' name='[Calculation_1624251410251649027]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Discount]&lt;= 0.05 THEN &quot;0-5%&quot;&#10;ELSEIF [Discount]&lt;= 0.1 THEN &quot;6-10%&quot;&#10;ELSEIF [Discount]&lt;= 0.15 THEN &quot;11-15%&quot;&#10;ELSEIF [Discount]&lt;= 0.20 THEN &quot;16-20%&quot;&#10;ELSE &quot;21%+&quot;&#10;END' />
      </column>
