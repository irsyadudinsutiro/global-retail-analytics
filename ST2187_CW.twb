      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Customer ID]) / TOTAL(COUNTD([Customer ID]))'>
          <table-calc ordering-field='[federated.0bd12731rz5glj1adx12t1i2935x].[none:Market:nk]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_1586815238282235904]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])*100' />
      </column>
      <column caption='Total Sales by Customers' datatype='real' name='[Calculation_1586815238292918274]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])' />
